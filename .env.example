# NotebookLX Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (default for local development)
DATABASE_URL=sqlite:///./notebooklx.db

# PostgreSQL (recommended for production and vector search)
# DATABASE_URL=postgresql://user:password@localhost:5432/notebooklx

# =============================================================================
# REDIS (for async task queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
INGESTION_QUEUE_NAME=notebooklx:ingestion

# =============================================================================
# OBJECT STORAGE (MinIO for local, S3/OSS for production)
# =============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=notebooklx

# For AWS S3:
# MINIO_ENDPOINT=https://s3.amazonaws.com
# MINIO_ACCESS_KEY=your-aws-access-key
# MINIO_SECRET_KEY=your-aws-secret-key
# MINIO_BUCKET=your-bucket-name

# =============================================================================
# AI PROVIDER - ZhipuAI / BigModel (default)
# =============================================================================
ZHIPUAI_API_KEY=your-zhipuai-api-key
ZHIPUAI_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPUAI_API_MODEL_ID=glm-4
ZHIPUAI_API_EMBEDDING_MODEL_ID=embedding-2

# Embedding configuration
ZHIPUAI_API_EMBEDDING_MAX_RETRIES=3
ZHIPUAI_API_EMBEDDING_RETRY_BASE_SECONDS=1.0
ZHIPUAI_API_EMBEDDING_REQUESTS_PER_MINUTE=120
ZHIPUAI_API_EMBEDDING_COST_PER_1K_TOKENS=0.0

# =============================================================================
# AI PROVIDER - OpenAI (alternative)
# =============================================================================
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# AUTHENTICATION (future)
# =============================================================================
# JWT_SECRET=your-random-secret-key
# JWT_EXPIRATION=86400
